import sys

class ProjectManager:
    """A simple class to handle core logic."""
    def __init__(self, name):
        self.name = name

    def greet_user(self):
        return f"System Initialized: Welcome to {self.name}."

def main():
    try:
        # Initialize your logic here
        app = ProjectManager("MyGitHubProject")
        print(app.greet_user())
        
    except Exception as e:
        print(f"An error occurred: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
